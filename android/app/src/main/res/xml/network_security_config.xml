<?xml version="1.0" encoding="utf-8"?>
<!--
    TrueAI LocalAI is, by design, a client for user-hosted local AI servers
    (Ollama, LocalAI, llama.cpp server, vLLM, etc.). Those servers run on
    arbitrary local addresses chosen by the user at runtime: localhost on the
    device, the Android emulator host (10.0.2.2), or any IP on the user's
    LAN such as 192.168.x.x or 10.x.x.x. We cannot enumerate those addresses
    ahead of time, and Android's <domain> element matches hostnames (or their
    subdomains), not CIDR ranges, so we permit cleartext at the base-config
    level. System CA trust anchors are still used for HTTPS.

    The <domain-config> block is kept purely as documentation of the intended
    usage: localhost, the loopback addresses, the emulator host bridge, and
    *.local mDNS hostnames.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
        <!-- Android emulator host loopback -->
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">10.0.3.2</domain>
        <!-- mDNS / Bonjour hosts -->
        <domain includeSubdomains="true">local</domain>
    </domain-config>
</network-security-config>
