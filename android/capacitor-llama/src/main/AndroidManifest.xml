<?xml version="1.0" encoding="utf-8"?>
<!--
    Capacitor `Llama` plugin manifest.

    Empty by design: the plugin reads model files only from app-private
    paths (typically `Filesystem.Directory.Data/models/<sha256>.gguf`)
    that callers pass in. It does NOT request READ_EXTERNAL_STORAGE,
    INTERNET, or any other permission — that keeps the plugin compatible
    with the future `offline` product flavor (PR 17), which strips
    `INTERNET` from the merged manifest.
-->
